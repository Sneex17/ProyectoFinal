@model HospitalTurnos.ViewModels.ColaViewModel
@{
    ViewData["Title"] = "Cola de Turnos";
}

 <!-- D) QUEUE TABLE -->
<section class="bg-surface-container-lowest rounded-3xl shadow-sm overflow-hidden mt-8 border border-outline-variant/10">
    <div class="px-8 py-6 border-b border-surface-container-high flex justify-between items-center bg-white">
        <h3 class="text-xl font-headline font-bold text-primary">Próximos en Cola</h3>
        <div class="flex items-center gap-2 text-on-surface-variant text-sm">
            <span>ℹ️ Los turnos se ordenan por prioridad jerárquica.</span>
        </div>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant text-[11px] uppercase tracking-widest font-bold">
                    <th class="px-8 py-4"># Turno</th>
                    <th class="px-6 py-4">Médico</th>
                    <th class="px-6 py-4">Prioridad</th>
                    <th class="px-6 py-4">Espera</th>
                    <th class="px-6 py-4">Hora</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-surface-container-high/50 bg-white">
                @foreach (var turno in Model.ColaEspera)
                {
                    string rowTintClass = "";
                    string badgeClass = "";

                    if (turno.PrioridadCss == "emergencia") { 
                        rowTintClass = "bg-error/5 hover:bg-error/10 transition-colors"; 
                        badgeClass = "bg-error text-white font-bold";
                    }
                    else if (turno.PrioridadCss == "prioritario") { 
                        rowTintClass = "bg-[#fedc97]/15 hover:bg-[#fedc97]/30 transition-colors"; 
                        badgeClass = "bg-[#fedc97] text-[#9e7611] font-bold";
                    }
                    else { 
                        rowTintClass = "bg-white hover:bg-surface-container-low transition-colors"; 
                        badgeClass = "bg-surface-container-highest text-on-surface-variant";
                    }

                    <tr class="@rowTintClass">
                        <td class="px-8 py-6 font-headline font-extrabold text-lg @(turno.PrioridadCss == "emergencia" ? "text-error" : "text-primary")">T-@turno.NumeroTurno</td>
                        <td class="px-6 py-6 text-on-surface-variant">Dra(o). @turno.MedicoNombre</td>
                        <td class="px-6 py-6">
                            <span class="@badgeClass text-[10px] px-2 py-1 rounded">@turno.PrioridadNombre</span>
                        </td>
                        <td class="px-6 py-6 @(turno.PrioridadCss == "emergencia" ? "text-error" : "text-on-surface-variant") text-sm font-bold">@turno.TiempoEspera.ToString(@"mm\:ss") min</td>
                        <td class="px-6 py-6 text-on-surface-variant text-xs font-medium">@turno.FechaHoraCreacion.ToString("HH:mm")</td>
                    </tr>
                }
                
                @if (!Model.ColaEspera.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-12 text-on-surface-variant">No hay pacientes esperando en la cola actualmente.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>



<div class="text-xs text-right text-outline-variant mt-4" id="last-update-indicator"></div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        // Configurar conexión a SignalR
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/turnoHub")
            .withAutomaticReconnect()
            .build();

        // Escuchar el evento de actualización
        connection.on("UpdateQueue", () => {
            console.log("Cola actualizada en servidor. Recargando...");
            window.location.reload();
        });

        // Iniciar conexión
        connection.start().catch(err => console.error("Error conectando a SignalR:", err));

        function updateLiveTimer() {
            const timerEl = document.getElementById('live-timer');
            if (timerEl) {
                const startStr = timerEl.getAttribute('data-start');
                if (startStr) {
                    const startTime = new Date(startStr);
                    const now = new Date();
                    const diffMs = now - startTime;
                    if (diffMs > 0) {
                        const totalSeconds = Math.floor(diffMs / 1000);
                        const h = String(Math.floor(totalSeconds / 3600)).padStart(2, '0');
                        const m = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0');
                        const s = String(totalSeconds % 60).padStart(2, '0');
                        timerEl.innerText = `${h}:${m}:${s}`;
                    }
                }
            }
        }
        setInterval(updateLiveTimer, 1000);
        updateLiveTimer();

        const initNow = new Date();
        document.getElementById('last-update-indicator').innerText = 'Última actualización: ' + initNow.toLocaleTimeString('es-ES');
    </script>
}
